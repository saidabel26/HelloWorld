@page
@model HelloWorld.Web.Pages.IndexModel
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Hello World</title>
</head>
<body>
    <h1>Hello World!</h1>

    <form method="post">
        <input asp-for="NewName" />
        <button type="submit">Agregar</button>
    </form>

    <h2>Nombres</h2>
    <ul>
        @foreach (var name in Model.Names)
        {
            <li>@name</li>
        }
    </ul>
</body>
</html>